# Copy to .env and fill with real values. Never commit .env.
# See ENV_AND_DASHBOARDS.md for Stripe, Paystack, M-Pesa, and other dashboard URLs.

# ── Database ─────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PERSISTENT=false
DB_CONNECT_TIMEOUT=20

# ── Application ──────────────────────────────────────────────────────────
APP_ENV=local
# Public API base used by some redirects (no trailing path segment required by all code paths)
APP_URL=https://YOUR_PUBLIC_API_HOST
# Web app origin (SvelteKit) — used for Stripe web success/cancel URLs and CORS fallbacks
APP_URL_FRONTEND=https://YOUR_WEB_APP_HOST
APP_FRONTEND_URL=https://YOUR_WEB_APP_HOST
FRONTEND_URL=https://YOUR_WEB_APP_HOST
APP_NAME=Mc Aviation
APP_LOGO_URL=
APP_PRIMARY_COLOR=#D71921
APP_SECONDARY_COLOR=#CC9933
APP_ADDRESS=

# ── Auth & internal jobs ─────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string
INTERNAL_API_KEY=generate_a_long_random_hex_key

# ── CORS (configured only via .env; see Application URLs above for fallbacks) ─
# Option A — Production: explicit allowlist only (comma-separated origins).
# CORS_ALLOWED_ORIGINS=https://YOUR_WEB_APP_HOST,https://www.yourdomain.com
#
# Option B — Leave CORS_ALLOWED_ORIGINS empty: allowed origins = FRONTEND_URL + APP_URL_FRONTEND +
#   APP_FRONTEND_URL + APP_URL + CORS_EXTRA_ORIGINS (+ optional blocks below).
CORS_EXTRA_ORIGINS=
# Vercel / preview frontends: set true and list origins (comma-separated)
CORS_ALLOW_VERCEL_PREVIEW=false
CORS_VERCEL_PREVIEW_ORIGINS=https://YOUR_VERCEL_PREVIEW.vercel.app
# Local SvelteKit/Vite: set true and list dev origins (comma-separated)
CORS_ALLOW_LOCAL_DEV=true
CORS_LOCAL_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# Preflight cache (seconds)
CORS_MAX_AGE=600
# Comma-separated; defaults are sensible for this API
# CORS_ALLOW_METHODS=GET, POST, OPTIONS, PUT, DELETE
# CORS_ALLOW_HEADERS=Content-Type, Authorization, X-Requested-With, X-Booking-Access-Token, X-Cargo-Access-Token

# ── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Signature timestamp tolerance (seconds); default 300
# STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
# Optional: override mobile return URLs (defaults: airlogix://payment/result?...)
# STRIPE_MOBILE_SUCCESS_URL=airlogix://payment/result?status=success&reference={REFERENCE}&session_id={CHECKOUT_SESSION_ID}
# STRIPE_MOBILE_CANCEL_URL=airlogix://payment/result?status=cancelled&reference={REFERENCE}

# ── Paystack ─────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
MPESA_CALLBACK_URL=https://YOUR_PUBLIC_API_HOST/api/airlogix/payments/mpesa/callback

# ── Onafriq ──────────────────────────────────────────────────────────────
ONAFRIQ_API_KEY=
ONAFRIQ_API_SECRET=
ONAFRIQ_MERCHANT_ID=
ONAFRIQ_ENV=sandbox
ONAFRIQ_CALLBACK_URL=https://YOUR_PUBLIC_API_HOST/api/airlogix/payments/onafriq/callback

# ── DPO ──────────────────────────────────────────────────────────────────
DPO_COMPANY_TOKEN=
DPO_SERVICE_TYPE=3854
DPO_ENV=sandbox
DPO_CALLBACK_URL=https://YOUR_PUBLIC_API_HOST/api/airlogix/payments/dpo/callback

# ── Email (Mailtrap / provider) ──────────────────────────────────────────
MAILTRAP_API_KEY=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Mc Aviation

# ── SMS (Twilio, optional) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Push (OneSignal) ─────────────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ── Media (Cloudinary) ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_UPLOAD_PRESET=

# ── Currency (Fixer or compatible) ───────────────────────────────────────
FIXER_API_KEY=
FIXER_BASE_URL=https://data.fixer.io/api/latest

# ── Booking / cargo access (optional overrides) ──────────────────────────
# BOOKING_HOLD_MINUTES=30
# BOOKING_ACCESS_TOKEN_TTL_SECONDS=1800
# BOOKING_ACCESS_RESEND_COOLDOWN_SECONDS=60
# CARGO_AWB_AIRLINE_PREFIX=450
# CARGO_ACCESS_TOKEN_TTL_SECONDS=86400
# CARGO_ACCESS_RESEND_COOLDOWN_SECONDS=60

# ── Cache TTLs (seconds) ─────────────────────────────────────────────────
# DESTINATIONS_CACHE_TTL=600
# CABIN_CLASSES_CACHE_TTL=600
# HOME_CONTENT_CACHE_TTL=300
# CURRENCY_RATES_CACHE_TTL=900
