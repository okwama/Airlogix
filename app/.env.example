# Copy to .env.local or .env (SvelteKit / Vite). Never commit real secrets.

# Must match your deployed PHP API prefix (see php_api/index.php)
VITE_API_BASE_URL=https://YOUR_PUBLIC_API_HOST/api/air

# Optional: only if the web UI uses Stripe.js directly (hosted Checkout uses server keys on API)
# VITE_STRIPE_PUBLIC_KEY=pk_test_REPLACE_ME

VITE_APP_NAME=Mc Aviation
VITE_APP_DESCRIPTION=Regional airline booking
VITE_APP_KEYWORDS=flights,booking,travel
VITE_APP_URL=https://YOUR_WEB_APP_HOST
VITE_APP_IMAGE=/favicon.png
VITE_APP_ICON=/favicon.png
VITE_APP_FAVICON=/favicon.png
VITE_APP_THEME_COLOR=#282F7E
VITE_APP_BACKGROUND_COLOR=#F5F7FA
VITE_APP_TEXT_COLOR=#121212
VITE_APP_SECONDARY_COLOR=#666666
VITE_APP_BORDER_COLOR=#E0E0E0
VITE_APP_SUCCESS_COLOR=#4CAF50
VITE_APP_WARNING_COLOR=#FFC107
VITE_APP_ERROR_COLOR=#F44336
VITE_APP_DEFAULT_CURRENCY=USD
